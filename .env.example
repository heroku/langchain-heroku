# ChatHeroku Test Harness Environment Variables
# Copy this file to .env and update with your actual values
# cp .env.example .env

# Required: Your Heroku Inference API credentials
INFERENCE_URL=https://your-inference-api-url
INFERENCE_KEY=your-heroku-inference-api-key
INFERENCE_MODEL_ID=your-model-id

# Optional: Additional configuration for tests
# These can be overridden in test_config.yaml or passed as arguments

# Model parameters (optional - defaults are used if not set)
# TEMPERATURE=0.1
# MAX_TOKENS=256
# TIMEOUT=60
# MAX_RETRIES=2
# TOP_P=0.95

# Test configuration (optional)
# STREAMING=false
# LOG_LEVEL=INFO
